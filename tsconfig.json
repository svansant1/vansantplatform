{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "jsx": "react-jsx",
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@debugger/*": ["svansai_debugger_backup/frontend/*"]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}